<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.control.CheckBox?>


<HBox xmlns="http://javafx.com/javafx/21" 
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.novabet.app.controllers.OnboardingController"
      stylesheets="@../styles/styles.css"
      styleClass="main-background">


    <VBox styleClass="brand-panel">
        
        <HBox alignment="TOP_LEFT" style="-fx-padding: 0 0 0px 0;">
            <ImageView fitHeight="120" preserveRatio="true" translateX="-40">
                <Image url="@../images/logo.png"/>
            </ImageView>
        </HBox>
        
        <VBox spacing="15">
            <Label text="Pariez là où les autres n'osent pas." styleClass="hero-title" wrapText="true"/>
            <Label text="Prédisez l'avenir de l'IA, du sport et de l'absurde. Ou pariez contre le consensus." styleClass="hero-subtitle" wrapText="true"/>
        </VBox>
        
        <Region VBox.vgrow="ALWAYS"/>
        
        <HBox spacing="10" styleClass="brand-footer">
            <Label text="1 247 marchés"/>
            <Label text="·"/>
            <Label text="48,2M$ échangés aujourd'hui"/>
        </HBox>
    </VBox>

    
    <StackPane styleClass="onboarding-panel">
        
        <VBox fx:id="step1Box" styleClass="step-box">
            <HBox spacing="6" style="-fx-padding: 0 0 8px 0;">
                <Region styleClass="progress-bar-step-active" prefWidth="40"/>
                <Region styleClass="progress-bar-step" prefWidth="40"/>
                <Region styleClass="progress-bar-step" prefWidth="40"/>
                <Region styleClass="progress-bar-step" prefWidth="40"/>
            </HBox>
            <Label text="ÉTAPE 1 SUR 4 · CRÉEZ VOTRE COMPTE"
                style="-fx-text-fill: -fx-text-muted; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 0 4px 0;"/>
            <Label text="Bienvenue sur NovaBet"
                style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 0 0 4px 0;"/>
            <Label text="Un compte vous donne accès aux marchés de prédictions, à un portefeuille, et quand vous serez prêt au Casino."
                style="-fx-text-fill: -fx-text-muted; -fx-font-size: 13px; -fx-padding: 0 0 50px 0;"
                wrapText="true"/>
            <HBox spacing="10">
                <Button text="Continuer avec Google" styleClass="btn-login"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"
                        onAction="#loginWithGoogle"/>
                <Button text="Continuer avec Apple" styleClass="btn-login"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"
                        onAction="#loginWithApple"/>
            </HBox>
            <HBox alignment="CENTER" spacing="12" style="-fx-padding: 16px 0 12px 0;">
                <Region style="-fx-background-color: #2d2e36a8; -fx-pref-height: 1px; -fx-max-height: 1px;"
                        HBox.hgrow="ALWAYS"/>
                <Label text="ou avec un email"
                    style="-fx-text-fill: -fx-text-muted; -fx-font-size: 12px; -fx-font-weight: 300;"/>
                <Region style="-fx-background-color: #2d2e36a8; -fx-pref-height: 1px; -fx-max-height: 1px;"
                        HBox.hgrow="ALWAYS"/>
            </HBox>
            <VBox spacing="10">

                <VBox spacing="4">
                    <HBox spacing="4">
                        <Label text="ADRESSE EMAIL"
                               style="-fx-text-fill: -fx-text-muted; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                        <Label text="*" style="-fx-text-fill: #FF4D4D; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    </HBox>
                    <TextField fx:id="emailField" promptText="vous@exemple.com" styleClass="input-field"/>
                    <Label fx:id="emailError" text="" styleClass="error-label"/>
                </VBox>

                <VBox spacing="4">
                    <HBox spacing="4">
                        <Label text="MOT DE PASSE"
                               style="-fx-text-fill: -fx-text-muted; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                        <Label text="*" style="-fx-text-fill: #FF4D4D; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    </HBox>
                    <PasswordField fx:id="passwordField" promptText="8+ caractères" styleClass="input-field"/>
                    <Label fx:id="passwordError" text="" styleClass="error-label"/>
                </VBox>

                <VBox spacing="4">
                    <HBox spacing="4">
                        <Label text="CONFIRMER LE MOT DE PASSE"
                               style="-fx-text-fill: -fx-text-muted; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                        <Label text="*" style="-fx-text-fill: #FF4D4D; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    </HBox>
                    <PasswordField fx:id="confirmPasswordField" promptText="Répétez le mot de passe" styleClass="input-field"/>
                    <Label fx:id="confirmPasswordError" text="" styleClass="error-label"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="CODE DE PARRAINAGE"
                           style="-fx-text-fill: -fx-text-muted; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="referralField" promptText="ex: NOVABET2026" styleClass="input-field"/>
                </VBox>

            </VBox>

            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 14px 0 0 0;">
                <CheckBox fx:id="termsCheckBox" styleClass="custom-checkbox"/>
                <Label text=" J'accepte les "
                    style="-fx-text-fill: -fx-text-muted; -fx-font-size: 12px;"/>
                <Label text="Conditions d'utilisation "
                    style="-fx-text-fill: white; -fx-font-size: 12px; -fx-underline: true; -fx-cursor: hand;"
                    onMouseClicked="#openTerms"/>
                <Label text="et confirme avoir 18 ans ou plus."
                    style="-fx-text-fill: -fx-text-muted; -fx-font-size: 12px;" wrapText="true"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" style="-fx-padding: 16px 0 0 0;">
                <Label text="Vous avez déjà un compte ? "
                    style="-fx-text-fill: -fx-text-muted; -fx-font-size: 12px;"/>
                <Label text="Se connecter"
                    style="-fx-text-fill: white; -fx-font-size: 12px; -fx-underline: true; -fx-cursor: hand;"
                    onMouseClicked="#openLogin"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="createAccountBtn" text="Créer le compte →" styleClass="btn-cyan"
                        onAction="#goToStep2" disable="true"/>
            </HBox>
        </VBox>

        <VBox fx:id="loginBox" styleClass="step-box" visible="false">
            <Label text="CONNEXION"
                   style="-fx-text-fill: -fx-text-muted; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 0 4px 0;"/>
            <Label text="Content de vous revoir"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 0 0 4px 0;"/>
            <Label text="Connectez-vous pour accéder à vos marchés et votre portefeuille."
                   style="-fx-text-fill: -fx-text-muted; -fx-font-size: 13px; -fx-padding: 0 0 20px 0;"
                   wrapText="true"/>

            <VBox spacing="12">
                <VBox spacing="6">
                    <Label text="ADRESSE EMAIL"
                           style="-fx-text-fill: -fx-text-muted; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="loginEmailField" promptText="vous@exemple.com" styleClass="input-field"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="MOT DE PASSE"
                           style="-fx-text-fill: -fx-text-muted; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <PasswordField fx:id="loginPasswordField" promptText="Votre mot de passe" styleClass="input-field"/>
                </VBox>
                <Label fx:id="loginError" style="-fx-text-fill: #FF4D4D; -fx-font-size: 12px;"/>
            </VBox>

            <HBox alignment="CENTER_LEFT" style="-fx-padding: 20px 0 0 0;">
                <Label text="Pas encore de compte ? "
                       style="-fx-text-fill: -fx-text-muted; -fx-font-size: 12px;"/>
                <Label text="Créer un compte"
                       style="-fx-text-fill: white; -fx-font-size: 12px; -fx-underline: true; -fx-cursor: hand;"
                       onMouseClicked="#goBackToStep1FromLogin"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Se connecter →" styleClass="btn-cyan" onAction="#loginUser"/>
            </HBox>
        </VBox>

        <VBox fx:id="cguBox" styleClass="step-box" visible="false">
            <Label text="CONDITIONS GÉNÉRALES"
                   style="-fx-text-fill: -fx-text-muted; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 0 4px 0;"/>
            <Label text="Conditions d'utilisation"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 0 0 16px 0;"/>
            
            <javafx.scene.control.ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0; -fx-border-color: #2D2E36; -fx-border-radius: 6px; -fx-border-width: 1px;" prefHeight="250">
                <VBox style="-fx-padding: 15px; -fx-spacing: 15px; -fx-background-color: #1A1B21;">
                    <Label text="1. Acceptation des conditions" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                    <Label text="En créant un compte sur NovaBet, vous acceptez d'être lié par ces conditions. Si vous n'acceptez pas, n'utilisez pas nos services." style="-fx-text-fill: -fx-text-muted; -fx-font-size: 12px;" wrapText="true"/>
                    
                    <Label text="2. Âge minimum requis" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                    <Label text="Vous devez avoir au moins 18 ans pour utiliser NovaBet. Toute infraction entraînera la suspension immédiate de votre compte." style="-fx-text-fill: -fx-text-muted; -fx-font-size: 12px;" wrapText="true"/>
                    
                    <Label text="3. Devise et paris (Simulation)" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                    <Label text="NovaBet est un projet scolaire. La devise utilisée ($NVB) n'a aucune valeur réelle. Les dépôts sont simulés et ne peuvent pas être retirés en argent réel." style="-fx-text-fill: -fx-text-muted; -fx-font-size: 12px;" wrapText="true"/>
                    
                    <Label text="4. Risques" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                    <Label text="Le trading sur des marchés prédictifs comporte des risques de perte de capital. Tradez de manière responsable." style="-fx-text-fill: -fx-text-muted; -fx-font-size: 12px;" wrapText="true"/>
                </VBox>
            </javafx.scene.control.ScrollPane>

            <HBox alignment="CENTER_LEFT" style="-fx-padding: 20px 0 0 0;">
                <Button text="← Retour à l'inscription" styleClass="btn-back" onAction="#closeTerms"/>
            </HBox>
        </VBox>

        <VBox fx:id="step2Box" styleClass="step-box" visible="false">
            <HBox spacing="6" style="-fx-padding: 0 0 8px 0;">
                <Region styleClass="progress-bar-step-active" prefWidth="40"/>
                <Region styleClass="progress-bar-step-active" prefWidth="40"/>
                <Region styleClass="progress-bar-step" prefWidth="40"/>
                <Region styleClass="progress-bar-step" prefWidth="40"/>
            </HBox>
            <Label text="ÉTAPE 2 SUR 4 · VÉRIFIEZ VOTRE IDENTITÉ"
                   style="-fx-text-fill: -fx-text-muted; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 0 4px 0;"/>
            <Label text="Vérification d'identité"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 0 0 4px 0;"/>
            <Label text="Pour des raisons réglementaires, nous devons vérifier votre identité avant d'activer votre compte."
                   style="-fx-text-fill: -fx-text-muted; -fx-font-size: 13px; -fx-padding: 0 0 25px 0;"
                   wrapText="true"/>

            <VBox styleClass="deposit-card" style="-fx-padding: 20px; -fx-spacing: 10px;">
                <Label text="Pièce d'identité valide (CNI, Passeport)"
                       style="-fx-text-fill: -fx-text-muted; -fx-font-size: 13px;"/>
                <Label text="Photo de vous avec la pièce d'identité"
                       style="-fx-text-fill: -fx-text-muted; -fx-font-size: 13px;"/>
                <Label text="Durée estimée : 2 à 5 minutes"
                       style="-fx-text-fill: -fx-text-muted; -fx-font-size: 13px;"/>
            </VBox>

            <HBox spacing="15" style="-fx-padding: 25px 0 0 0;">
                <Button text="← Retour" styleClass="btn-back" onAction="#goBackToStep1"/>
                <Button text="Commencer la vérification →" styleClass="btn-cyan" onAction="#goToStep3"/>
            </HBox>
        </VBox>


        
        <VBox fx:id="step3Box" styleClass="step-box" visible="false">
            <Label text="ÉTAPE 3 SUR 4 · ALIMENTEZ VOTRE COMPTE (OPTIONNEL)" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 10px; -fx-font-weight: bold;"/>
            
            <Label text="Déposez des $NVB pour commencer" styleClass="brand-title" style="-fx-font-size: 28px;"/>
            <Label text="Le $NVB est la monnaie de l'application. Ce premier dépôt est optionnel, vous pourrez le faire plus tard." style="-fx-text-fill: -fx-text-muted; -fx-font-size: 13px;"/>
            
            <HBox spacing="15" style="-fx-padding: 20px 0;">
                <VBox fx:id="card50" styleClass="deposit-card" onMouseClicked="#selectAmount50">
                    <Label text="50$" styleClass="card-price"/>
                    <Label text="50 $NVB" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 11px;"/>
                </VBox>
                <VBox fx:id="card250" styleClass="deposit-card" onMouseClicked="#selectAmount250">
                    <Label text="250$" styleClass="card-price"/>
                    <Label text="250 $NVB + bonus 5%" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 11px;"/>
                </VBox>
                <VBox fx:id="card1000" styleClass="deposit-card" onMouseClicked="#selectAmount1000">
                    <Label text="1 000$" styleClass="card-price"/>
                    <Label text="1 000 $NVB + bonus 10%" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 11px;"/>
                </VBox>
            </HBox>
            <Label text="OU ENTREZ UN MONTANT PERSONNALISÉ" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 10px; -fx-font-weight: bold;"/>
            <TextField fx:id="customAmountField" promptText="500.00" styleClass="input-field" style="-fx-font-size: 18px; -fx-font-family: 'Courier New';"/>
            
            <Label text="MÉTHODE DE PAIEMENT" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 15px 0 0 0;"/>
            <HBox styleClass="payment-container" spacing="5">
                <Button fx:id="btnCard" text="Carte" styleClass="payment-btn" onAction="#selectPaymentMethod" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button fx:id="btnCrypto" text="USDC" styleClass="payment-btn" onAction="#selectPaymentMethod" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button fx:id="btnBank" text="Virement" styleClass="payment-btn" onAction="#selectPaymentMethod" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button fx:id="btnApplePay" text="Apple Pay" styleClass="payment-btn" onAction="#selectPaymentMethod" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>

            <Label text="En déposant, vous acceptez les CGU · Identité vérifiée ✓" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 11px; -fx-padding: 30px 0 0 0;"/>
            <HBox spacing="15">
                <Button text="← Retour" styleClass="btn-back" onAction="#goBackToStep2"/>
                <Button text="Passer cette étape" styleClass="btn-back" onAction="#skipToStep4"/>
                <Button fx:id="depositButton" text="Déposer →" styleClass="btn-cyan" onAction="#goToStep4" disable="true"/>
            </HBox>
        </VBox>

        
        <VBox fx:id="step4Box" styleClass="step-box" visible="false" spacing="30">
            <HBox spacing="6" style="-fx-padding: 0 0 8px 0;">
                <Region styleClass="progress-bar-step-active" prefWidth="40"/>
                <Region styleClass="progress-bar-step-active" prefWidth="40"/>
                <Region styleClass="progress-bar-step-active" prefWidth="40"/>
                <Region styleClass="progress-bar-step-active" prefWidth="40"/>
            </HBox>
            
            <VBox spacing="4">
                <Label text="ÉTAPE 4 SUR 4 · PERSONNALISEZ VOTRE FLUX" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                <Label text="Que voulez-vous trader ?" styleClass="brand-title" style="-fx-font-size: 28px; -fx-text-fill: white;"/>
                <Label text="Sélectionnez au moins 2 catégories pour personnaliser votre flux." style="-fx-text-fill: -fx-text-muted; -fx-font-size: 13px;"/>
            </VBox>
            
            <VBox spacing="15">
                <HBox spacing="15">
                    <VBox fx:id="catAi" styleClass="category-card" onMouseClicked="#toggleCategory" alignment="CENTER" prefWidth="140" prefHeight="100" spacing="5">
                        <Label text="🤖" style="-fx-font-size: 26px; -fx-font-family: 'Segoe UI Emoji', 'Apple Color Emoji';"/>
                        <Label text="IA &amp; Tech" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox fx:id="catSport" styleClass="category-card" onMouseClicked="#toggleCategory" alignment="CENTER" prefWidth="140" prefHeight="100" spacing="5">
                        <Label text="⚽" style="-fx-font-size: 26px; -fx-font-family: 'Segoe UI Emoji', 'Apple Color Emoji';"/>
                        <Label text="Sport" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox fx:id="catPolitics" styleClass="category-card" onMouseClicked="#toggleCategory" alignment="CENTER" prefWidth="140" prefHeight="100" spacing="5">
                        <Label text="💼" style="-fx-font-size: 26px; -fx-font-family: 'Segoe UI Emoji', 'Apple Color Emoji';"/>
                        <Label text="Politique" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox fx:id="catCrypto" styleClass="category-card" onMouseClicked="#toggleCategory" alignment="CENTER" prefWidth="140" prefHeight="100" spacing="5">
                        <Label text="🪙" style="-fx-font-size: 26px; -fx-text-fill: white; -fx-font-family: 'Segoe UI Emoji', 'Apple Color Emoji';"/>
                        <Label text="Crypto" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>
                <HBox spacing="15">
                    <VBox fx:id="catScience" styleClass="category-card" onMouseClicked="#toggleCategory" alignment="CENTER" prefWidth="140" prefHeight="100" spacing="5">
                        <Label text="🧬" style="-fx-font-size: 26px; -fx-font-family: 'Segoe UI Emoji', 'Apple Color Emoji';"/>
                        <Label text="Science" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox fx:id="catAbsurd" styleClass="category-card" onMouseClicked="#toggleCategory" alignment="CENTER" prefWidth="140" prefHeight="100" spacing="5">
                        <Label text="👽" style="-fx-font-size: 26px; -fx-font-family: 'Segoe UI Emoji', 'Apple Color Emoji';"/>
                        <Label text="Absurde" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox fx:id="catFinance" styleClass="category-card" onMouseClicked="#toggleCategory" alignment="CENTER" prefWidth="140" prefHeight="100" spacing="5">
                        <Label text="📈" style="-fx-font-size: 26px; -fx-font-family: 'Segoe UI Emoji', 'Apple Color Emoji';"/>
                        <Label text="Finance" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox fx:id="catCulture" styleClass="category-card" onMouseClicked="#toggleCategory" alignment="CENTER" prefWidth="140" prefHeight="100" spacing="5">
                        <Label text="🎬" style="-fx-font-size: 26px; -fx-font-family: 'Segoe UI Emoji', 'Apple Color Emoji';"/>
                        <Label text="Culture" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>
            </VBox>

            <HBox spacing="15" style="-fx-padding: 30px 0 0 0;">
                <Button text="← Retour" styleClass="btn-back" onAction="#goBackToStep3"/>
                <Button fx:id="finishBtn" text="Entrer dans NovaBet →" styleClass="btn-cyan" onAction="#finishOnboarding" disable="true"/>
            </HBox>
        </VBox>

    </StackPane>
</HBox>
